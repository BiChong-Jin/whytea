YOUTUBE_API_KEY=your_youtube_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
POLL_INTERVAL_SECONDS=5
ANALYSIS_INTERVAL_SECONDS=30
MAX_COMMENTS_PER_BATCH=200
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Must be at least 32 random characters — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_long_random_secret_minimum_32_chars

# Comma-separated allowed origins. Use * to allow all (not recommended for production).
CORS_ORIGINS=*

# Token expiry in hours
JWT_TOKEN_EXPIRE_HOURS=24

# SQLAlchemy URL. Defaults to a local file; point at a persistent disk mount
# in production, e.g. sqlite:////var/data/users.db
DATABASE_URL=sqlite:///./users.db
